@page "/history"
@inject Services.AccountHistoryService HistoryService

<div class="max-w-4xl space-y-6">
    <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">History</h1>
        <p class="text-muted-foreground mt-1">All created email accounts.</p>
    </div>

    <div class="bg-card rounded-xl border border-border p-6">
        <!-- Filters -->
        <div class="flex items-center justify-end mb-4">
            <div class="flex items-center gap-3">
                <select @bind="filterProvider" @bind:after="ApplyFilters"
                        class="p-1.5 border border-border rounded-md bg-background text-foreground text-sm">
                    <option value="">All Providers</option>
                    <option value="Outlook">Outlook</option>
                    <option value="Gmail">Gmail</option>
                    <option value="Yahoo">Yahoo</option>
                </select>
                <select @bind="filterStatus" @bind:after="ApplyFilters"
                        class="p-1.5 border border-border rounded-md bg-background text-foreground text-sm">
                    <option value="">All Status</option>
                    <option value="Success">Success</option>
                    <option value="Failed">Failed</option>
                </select>
                <input type="date" @bind="filterDate" @bind:after="ApplyFilters"
                       class="p-1.5 border border-border rounded-md bg-background text-foreground text-sm" />
                <select @bind="sortOrder" @bind:after="ApplyFilters"
                        class="p-1.5 border border-border rounded-md bg-background text-foreground text-sm">
                    <option value="newest">Newest First</option>
                    <option value="oldest">Oldest First</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        @if (!PagedEntries.Any())
        {
            <p class="text-sm text-muted-foreground text-center py-8">No accounts in history.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-border text-left text-muted-foreground">
                            <th class="py-2 pr-4">Email</th>
                            <th class="py-2 pr-4">Password</th>
                            <th class="py-2 pr-4">Provider</th>
                            <th class="py-2 pr-4">Created</th>
                            <th class="py-2">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in PagedEntries)
                        {
                            <tr class="border-b border-border last:border-0">
                                <td class="py-2 pr-4 font-medium">@entry.Email</td>
                                <td class="py-2 pr-4 font-mono text-xs">@entry.Password</td>
                                <td class="py-2 pr-4">@entry.Provider</td>
                                <td class="py-2 pr-4 text-muted-foreground">@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="py-2">
                                    <span class="@(entry.Status == "Success" ? "text-green-600" : "text-destructive")">
                                        @entry.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Pagination -->
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-border">
            <div class="flex items-center gap-2 text-sm text-muted-foreground">
                <span>Rows per page:</span>
                <select @bind="pageSize" @bind:after="ApplyFilters"
                        class="p-1 border border-border rounded-md bg-background text-foreground text-sm">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <div class="flex items-center gap-2 text-sm text-muted-foreground">
                <span>@PageInfo</span>
            </div>
            <div class="flex items-center gap-1">
                <button @onclick="PreviousPage" disabled="@(currentPage <= 1)"
                        class="w-8 h-8 inline-flex items-center justify-center rounded-md border border-border bg-card text-foreground text-sm hover:bg-muted disabled:opacity-40 disabled:cursor-default disabled:hover:bg-card">
                    ‹
                </button>
                @for (int p = 1; p <= TotalPages; p++)
                {
                    var pageNum = p;
                    <button @onclick="@(() => GoToPage(pageNum))"
                            class="w-8 h-8 inline-flex items-center justify-center rounded-md border @(pageNum == currentPage ? "border-primary bg-primary text-primary-foreground" : "border-border bg-card text-foreground") text-sm hover:bg-muted">
                        @pageNum
                    </button>
                }
                <button @onclick="NextPage" disabled="@(currentPage >= TotalPages)"
                        class="w-8 h-8 inline-flex items-center justify-center rounded-md border border-border bg-card text-foreground text-sm hover:bg-muted disabled:opacity-40 disabled:cursor-default disabled:hover:bg-card">
                    ›
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string filterProvider = "";
    private string filterStatus = "";
    private DateTime? filterDate;
    private string sortOrder = "newest";
    private int pageSize = 10;
    private int currentPage = 1;

    private IEnumerable<Services.AccountHistoryEntry> FilteredEntries
    {
        get
        {
            var entries = HistoryService.Entries.AsEnumerable();

            if (!string.IsNullOrEmpty(filterProvider))
                entries = entries.Where(e => e.Provider == filterProvider);

            if (!string.IsNullOrEmpty(filterStatus))
                entries = entries.Where(e => e.Status == filterStatus);

            if (filterDate.HasValue)
                entries = entries.Where(e => e.CreatedAt.Date == filterDate.Value.Date);

            entries = sortOrder == "newest"
                ? entries.OrderByDescending(e => e.CreatedAt)
                : entries.OrderBy(e => e.CreatedAt);

            return entries;
        }
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredEntries.Count() / pageSize));

    private IEnumerable<Services.AccountHistoryEntry> PagedEntries
    {
        get
        {
            var start = (currentPage - 1) * pageSize;
            return FilteredEntries.Skip(start).Take(pageSize);
        }
    }

    private string PageInfo
    {
        get
        {
            var total = FilteredEntries.Count();
            if (total == 0) return "No results";
            var start = (currentPage - 1) * pageSize + 1;
            var end = Math.Min(currentPage * pageSize, total);
            return $"Showing {start}–{end} of {total}";
        }
    }

    private void ApplyFilters()
    {
        currentPage = 1;
    }

    private void GoToPage(int page)
    {
        currentPage = Math.Clamp(page, 1, TotalPages);
    }

    private void PreviousPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }
}

@page "/settings"
@inject Services.SettingsService SettingsService

<div class="max-w-2xl space-y-6">
    <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Settings</h1>
        <p class="text-muted-foreground mt-1">Configure API keys and defaults.</p>
    </div>

    <!-- Browser -->
    <div class="bg-card rounded-xl border border-border p-6 space-y-3">
        <div>
            <div class="font-semibold text-foreground">Browser</div>
            <div class="text-sm text-muted-foreground mt-0.5">Default browser for account creation.</div>
        </div>
        <select @bind="SettingsService.Settings.Browser"
                class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm">
            <option value="firefox">Firefox</option>
            <option value="chrome">Chrome</option>
            <option value="undetected-chrome">Undetected Chrome</option>
        </select>
    </div>

    <!-- Captcha Services -->
    <div class="bg-card rounded-xl border border-border p-6 space-y-3">
        <div>
            <div class="font-semibold text-foreground">Captcha Services</div>
            <div class="text-sm text-muted-foreground mt-0.5">Select a captcha solving service and enter its API key.</div>
        </div>
        <div>
            <label class="text-sm text-muted-foreground mb-1 block">Captcha Service</label>
            <select @bind="selectedCaptchaService" @bind:after="OnCaptchaServiceChanged"
                    class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm">
                <option value="">— Select service —</option>
                <option value="capsolver">Capsolver</option>
                <option value="nopecha">Nopecha</option>
            </select>
        </div>
        @if (selectedCaptchaService == "capsolver")
        {
            <div>
                <label class="text-sm text-muted-foreground mb-1 block">Capsolver API Key</label>
                <input @bind="SettingsService.Settings.CapsolverKey" type="password" placeholder="Enter Capsolver API key..."
                       class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm" />
            </div>
        }
        @if (selectedCaptchaService == "nopecha")
        {
            <div>
                <label class="text-sm text-muted-foreground mb-1 block">Nopecha API Key</label>
                <input @bind="SettingsService.Settings.NopechaKey" type="password" placeholder="Enter Nopecha API key..."
                       class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm" />
            </div>
        }
    </div>

    <!-- SMS Services -->
    <div class="bg-card rounded-xl border border-border p-6 space-y-3">
        <div>
            <div class="font-semibold text-foreground">SMS Services</div>
            <div class="text-sm text-muted-foreground mt-0.5">Select an SMS verification service and enter its credentials.</div>
        </div>
        <div>
            <label class="text-sm text-muted-foreground mb-1 block">Default SMS Service</label>
            <select @bind="selectedSmsService" @bind:after="OnSmsServiceChanged"
                    class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm">
                <option value="">— Select service —</option>
                <option value="smspool">SmsPool</option>
                <option value="5sim">5Sim</option>
                <option value="getsmscode">GetsmsCode</option>
            </select>
        </div>
        @if (selectedSmsService == "smspool")
        {
            <div>
                <label class="text-sm text-muted-foreground mb-1 block">SmsPool Token</label>
                <input @bind="SettingsService.Settings.SmsPoolToken" type="password" placeholder="Enter SmsPool token..."
                       class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm" />
            </div>
        }
        @if (selectedSmsService == "5sim")
        {
            <div>
                <label class="text-sm text-muted-foreground mb-1 block">5Sim API Key</label>
                <input @bind="SettingsService.Settings.FiveSimToken" type="password" placeholder="Enter 5Sim API key..."
                       class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm" />
            </div>
        }
        @if (selectedSmsService == "getsmscode")
        {
            <div class="space-y-3">
                <div>
                    <label class="text-sm text-muted-foreground mb-1 block">GetsmsCode Username</label>
                    <input @bind="SettingsService.Settings.GetsmsCodeUser" placeholder="Enter username..."
                           class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm" />
                </div>
                <div>
                    <label class="text-sm text-muted-foreground mb-1 block">GetsmsCode Token</label>
                    <input @bind="SettingsService.Settings.GetsmsCodeToken" type="password" placeholder="Enter token..."
                           class="w-full p-2 border border-border rounded-md bg-background text-foreground text-sm" />
                </div>
            </div>
        }
    </div>

    <div class="flex justify-end">
        <button @onclick="Save"
                class="px-6 py-3 bg-primary text-primary-foreground rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
            Save Settings
        </button>
    </div>

    @if (showSaved)
    {
        <div class="bg-green-100 border border-green-200 text-green-800 rounded-lg p-4 text-sm">
            Settings saved successfully.
        </div>
    }
</div>

@code {
    private bool showSaved;
    private string selectedCaptchaService = "";
    private string selectedSmsService = "";

    protected override void OnInitialized()
    {
        // Infer selected services from existing keys
        if (!string.IsNullOrEmpty(SettingsService.Settings.CapsolverKey))
            selectedCaptchaService = "capsolver";
        else if (!string.IsNullOrEmpty(SettingsService.Settings.NopechaKey))
            selectedCaptchaService = "nopecha";

        if (!string.IsNullOrEmpty(SettingsService.Settings.SmsPoolToken))
            selectedSmsService = "smspool";
        else if (!string.IsNullOrEmpty(SettingsService.Settings.FiveSimToken)
              || !string.IsNullOrEmpty(SettingsService.Settings.GetsmsCodeToken)
              || !string.IsNullOrEmpty(SettingsService.Settings.GetsmsCodeUser))
        {
            // Infer from DefaultSmsService or from which keys are set
            selectedSmsService = SettingsService.Settings.DefaultSmsService;
        }
    }

    private void OnCaptchaServiceChanged()
    {
        // Clear keys for unselected services
        if (selectedCaptchaService != "capsolver")
            SettingsService.Settings.CapsolverKey = "";
        if (selectedCaptchaService != "nopecha")
            SettingsService.Settings.NopechaKey = "";
    }

    private void OnSmsServiceChanged()
    {
        SettingsService.Settings.DefaultSmsService = selectedSmsService;

        // Clear keys for unselected services
        if (selectedSmsService != "smspool")
            SettingsService.Settings.SmsPoolToken = "";
        if (selectedSmsService != "5sim")
            SettingsService.Settings.FiveSimToken = "";
        if (selectedSmsService != "getsmscode")
        {
            SettingsService.Settings.GetsmsCodeUser = "";
            SettingsService.Settings.GetsmsCodeToken = "";
        }
    }

    private void Save()
    {
        SettingsService.Save();
        showSaved = true;
        _ = Task.Run(async () =>
        {
            await Task.Delay(2000);
            showSaved = false;
            await InvokeAsync(StateHasChanged);
        });
    }
}

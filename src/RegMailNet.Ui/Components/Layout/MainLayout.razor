@inherits LayoutComponentBase
@inject NavigationManager Nav
@implements IDisposable

<BbToastProvider />
<BbDialogProvider />

<div class="flex min-h-screen bg-background">
    <aside class="w-56 border-r border-border bg-card p-4 flex flex-col gap-4">
        <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-lg bg-primary flex items-center justify-center">
                <span class="text-primary-foreground font-bold text-xs">R</span>
            </div>
            <span class="font-semibold text-sm text-foreground">RegMailNet</span>
        </div>
        <NavMenu />
        <div class="mt-auto">
            <div class="text-[10px] text-muted-foreground space-y-0.5">
                <div class="flex items-center justify-between">
                    <span>Quick nav:</span>
                </div>
                <div class="flex items-center justify-between">
                    <span>Dashboard</span>
                    <kbd class="px-1 py-0.5 bg-muted rounded text-[9px]">Alt+1</kbd>
                </div>
                <div class="flex items-center justify-between">
                    <span>Create</span>
                    <kbd class="px-1 py-0.5 bg-muted rounded text-[9px]">Alt+2</kbd>
                </div>
                <div class="flex items-center justify-between">
                    <span>History</span>
                    <kbd class="px-1 py-0.5 bg-muted rounded text-[9px]">Alt+3</kbd>
                </div>
                <div class="flex items-center justify-between">
                    <span>Proxies</span>
                    <kbd class="px-1 py-0.5 bg-muted rounded text-[9px]">Alt+4</kbd>
                </div>
                <div class="flex items-center justify-between">
                    <span>Settings</span>
                    <kbd class="px-1 py-0.5 bg-muted rounded text-[9px]">Alt+5</kbd>
                </div>
            </div>
        </div>
    </aside>
    <main class="flex-1 flex flex-col">
        <article class="flex-1 p-4">
            @Body
        </article>
    </main>
</div>

@code {
    private readonly string[] _routes = { "/", "/create", "/history", "/proxies", "/settings" };

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
